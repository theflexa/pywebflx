{
  "manifest_version": 3,
  "name": "PyWebFlx Bridge",
  "version": "1.0.0",
  "description": "Bridge between PyWebFlx Python library and Chrome browser automation",
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
